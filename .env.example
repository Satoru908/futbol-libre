PORT=8787

# ⚡ ARQUITECTURA HÍBRIDA - CONFIGURACIÓN CRÍTICA
# Backend maneja playlists (.m3u8) con IP limpia → Evita error 403
# Cloudflare Worker maneja segmentos (.ts) → Escala infinito, gratis
# 
# IMPORTANTE: Desplegar worker primero con: cd cloudflare-worker && wrangler deploy
# Luego copiar la URL aquí (ejemplo: https://futbol-libre-hls-proxy.tuusuario.workers.dev)
CLOUDFLARE_WORKER_URL=https://futbol-libre-hls-proxy.albedo-bots.workers.dev

# Ejemplo de configuración de URL real para ESPN (sin iframe)
# STREAM_URL_{ID_CANAL}
STREAM_URL_ESPN=https://qzv4jmsc.fubohd.com/espn/mono.m3u8?token=bfffa0429d7f07cdb39804fa9e4c1800263d2222-10-1773650569-1773632569

# Configuración del Proxy (Headers que se envían al origen)
ALLOWED_ORIGINS=*
UPSTREAM_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
